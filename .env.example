# PiBox environment configuration
# Copy to `.env` and edit. Values here override the hardcoded defaults in
# config.py but lose to systemd `Environment=` directives.

# Where SQLite DB + images live
PIBOX_DATA_DIR=/var/pibox

# Web server (Flask) port
PIBOX_HTTP_PORT=8080

# WebSocket server port
PIBOX_WS_PORT=8081

# Flask session secret — change this in production
# PIBOX_SECRET_KEY=change-me
